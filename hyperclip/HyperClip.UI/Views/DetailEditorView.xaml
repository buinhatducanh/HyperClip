<UserControl x:Class="HyperClip.UI.Views.DetailEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#121212">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel>
            <!-- Video Title -->
            <TextBlock Text="{Binding Workspace.VideoTitle}" FontSize="14" FontWeight="SemiBold"
                       Foreground="#F5F5F5" TextWrapping="Wrap" Margin="0,0,0,16"
                       Visibility="{Binding Workspace, Converter={StaticResource BoolToVisConverter}}"/>

            <!-- TRIM -->
            <TextBlock Text="TRIM" FontSize="10" FontWeight="Bold" Foreground="#A3A3A3" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding TrimStart, StringFormat={}{0:F1}s}"
                           FontSize="11" Foreground="#A3A3A3" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="300" Value="{Binding TrimStart}" Margin="8,0"/>
                <TextBlock Grid.Column="2" Text="{Binding TrimEnd, StringFormat={}{0:F1}s}"
                           FontSize="11" Foreground="#A3A3A3" VerticalAlignment="Center"/>
            </Grid>

            <!-- SPEED -->
            <TextBlock Text="SPEED" FontSize="10" FontWeight="Bold" Foreground="#A3A3A3" Margin="0,8,0,4"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <RadioButton Content="0.5x" Tag="0.5" IsChecked="False"
                             Background="#1E1E1E" Foreground="#F5F5F5" Margin="0,0,8,0"/>
                <RadioButton Content="1x" Tag="1.0" IsChecked="True"
                             Background="#1E1E1E" Foreground="#F5F5F5" Margin="0,0,8,0"/>
                <RadioButton Content="1.5x" Tag="1.5" IsChecked="False"
                             Background="#1E1E1E" Foreground="#F5F5F5" Margin="0,0,8,0"/>
                <RadioButton Content="2x" Tag="2.0" IsChecked="False"
                             Background="#1E1E1E" Foreground="#F5F5F5" Margin="0,0,8,0"/>
            </StackPanel>

            <!-- BACKGROUND -->
            <TextBlock Text="BACKGROUND" FontSize="10" FontWeight="Bold" Foreground="#A3A3A3" Margin="0,8,0,4"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Black" Width="60" Margin="0,0,8,0"
                        Command="{Binding SetBackgroundColorCommand}" CommandParameter="#000000"
                        Background="#1E1E1E" Foreground="#F5F5F5" BorderThickness="0" Padding="8,4"/>
                <Button Content="White" Width="60" Margin="0,0,8,0"
                        Command="{Binding SetBackgroundColorCommand}" CommandParameter="#FFFFFF"
                        Background="#1E1E1E" Foreground="#F5F5F5" BorderThickness="0" Padding="8,4"/>
            </StackPanel>

            <!-- EXPORT -->
            <TextBlock Text="EXPORT" FontSize="10" FontWeight="Bold" Foreground="#A3A3A3" Margin="0,8,0,4"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="FPS" FontSize="10" Foreground="#A3A3A3" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" SelectedValue="{Binding ExportFps}" SelectedValuePath="Tag"
                          Background="#1E1E1E" Foreground="#F5F5F5" Padding="8,4">
                    <ComboBoxItem Content="24" Tag="24"/>
                    <ComboBoxItem Content="30" Tag="30"/>
                    <ComboBoxItem Content="60" Tag="60"/>
                </ComboBox>
            </Grid>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Codec" FontSize="10" Foreground="#A3A3A3" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" SelectedValue="{Binding ExportCodec}" SelectedValuePath="Tag"
                          Background="#1E1E1E" Foreground="#F5F5F5" Padding="8,4">
                    <ComboBoxItem Content="H.264" Tag="h264"/>
                    <ComboBoxItem Content="HEVC" Tag="hevc"/>
                </ComboBox>
            </Grid>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Preset" FontSize="10" Foreground="#A3A3A3" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" SelectedValue="{Binding ExportPreset}" SelectedValuePath="Tag"
                          Background="#1E1E1E" Foreground="#F5F5F5" Padding="8,4">
                    <ComboBoxItem Content="p1 (fastest)" Tag="p1"/>
                    <ComboBoxItem Content="p2" Tag="p2"/>
                    <ComboBoxItem Content="p3" Tag="p3"/>
                </ComboBox>
            </Grid>

            <!-- Rendering Progress -->
            <TextBlock Text="Rendering..." FontSize="11" Foreground="#3B82F6"
                       Visibility="{Binding IsRendering, Converter={StaticResource BoolToVisConverter}}"
                       Margin="0,0,0,4"/>
            <ProgressBar Value="{Binding Workspace.RenderProgress}" Maximum="100" Height="4"
                         Background="#333" Foreground="#3B82F6" BorderThickness="0"
                         Visibility="{Binding IsRendering, Converter={StaticResource BoolToVisConverter}}"
                         Margin="0,0,0,12"/>

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Padding="16,8" Margin="0,0,8,0"
                        Command="{Binding CancelRenderCommand}"
                        Background="#333" Foreground="#A3A3A3" BorderThickness="0"
                        Visibility="{Binding IsRendering, Converter={StaticResource BoolToVisConverter}}"/>
                <Button Content="Render" Padding="20,8"
                        Command="{Binding StartRenderCommand}"
                        Background="#3B82F6" Foreground="White" BorderThickness="0" FontWeight="600">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2563EB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
