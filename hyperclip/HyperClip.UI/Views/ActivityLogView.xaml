<UserControl x:Class="HyperClip.UI.Views.ActivityLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Activity" FontSize="10" FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontFamily="{StaticResource SansFont}" Margin="0,0,0,6"/>

        <!-- Log entries -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="150"
                      Visibility="{Binding Entries.Count, Converter={StaticResource IntToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding Entries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock FontSize="9" TextWrapping="Wrap" Margin="0,0,0,2"
                                   FontFamily="{StaticResource MonoFont}"
                                   Foreground="{Binding Type, Converter={StaticResource ActivityLogTypeToBrushConverter}}">
                            <Run Text="{Binding Timestamp, Mode=OneWay}"/>
                            <Run Text=" &#x2014; " Foreground="{StaticResource TextTertiaryBrush}"/>
                            <Run Text="{Binding Message, Mode=OneWay}"/>
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding Entries.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=invert}">
            <TextBlock Text="&#x2205;" FontSize="18" HorizontalAlignment="Center"
                       Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="No activity yet" FontSize="11"
                       Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
