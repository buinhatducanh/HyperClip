<UserControl x:Class="HyperClip.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel MaxWidth="600">
            <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

            <!-- DETECTION -->
            <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="DETECTION" Style="{StaticResource SectionHeaderStyle}"/>
                    <CheckBox Content="Enable auto-detection (poll channels)"
                              IsChecked="{Binding Settings.PollingEnabled}"
                              Style="{StaticResource InputCheckBoxStyle}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Poll interval (ms)" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding Settings.PollIntervalMs}"
                                 Style="{StaticResource InputTextBoxStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- DOWNLOAD -->
            <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="DOWNLOAD" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Quality" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" SelectedValue="{Binding Settings.AutoDownloadQuality}"
                                  Style="{StaticResource InputComboBoxStyle}">
                            <ComboBoxItem Content="360p" Tag="360"/>
                            <ComboBoxItem Content="720p" Tag="720"/>
                            <ComboBoxItem Content="1080p" Tag="1080"/>
                        </ComboBox>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Max concurrent" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding Settings.MaxConcurrentDownloads}"
                                 Style="{StaticResource InputTextBoxStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- RENDER -->
            <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="RENDER" Style="{StaticResource SectionHeaderStyle}"/>
                    <CheckBox Content="Auto-render after download"
                              IsChecked="{Binding Settings.AutoRender}"
                              Style="{StaticResource InputCheckBoxStyle}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Max concurrent renders" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding Settings.MaxConcurrentRenders}"
                                 Style="{StaticResource InputTextBoxStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- BEHAVIOR -->
            <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="BEHAVIOR" Style="{StaticResource SectionHeaderStyle}"/>
                    <CheckBox Content="Minimize to tray on close"
                              IsChecked="{Binding Settings.MinimizeToTray}"
                              Style="{StaticResource InputCheckBoxStyle}" Margin="0,0,0,8"/>
                    <CheckBox Content="Quit app when closing"
                              IsChecked="{Binding Settings.QuitOnClose}"
                              Style="{StaticResource InputCheckBoxStyle}"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                           Foreground="{StaticResource SuccessBrush}"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="Save" Command="{Binding SaveCommand}"
                        Style="{StaticResource AccentButtonStyle}" Padding="20,8"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
