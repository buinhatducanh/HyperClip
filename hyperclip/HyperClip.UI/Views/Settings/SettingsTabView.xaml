<UserControl x:Class="HyperClip.UI.Views.Settings.SettingsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HyperClip.UI.Views.Settings"
             Background="{StaticResource BgBrush}">
    <TabControl x:Name="SettingsTabs" Background="Transparent"
                BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1" Padding="0" Margin="16">

        <TabControl.ItemContainerStyle>
            <Style TargetType="TabItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="FontFamily" Value="{StaticResource SansFont}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="14,8"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}" Margin="2,0">
                                <ContentPresenter ContentSource="Header"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource GlassSurfaceBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentGlowBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </TabControl.ItemContainerStyle>

        <!-- Detection -->
        <TabItem Header="Detection">
            <StackPanel>
                <TextBlock Text="Detection" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="POLLER" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Channels" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding DetectionTab.ChannelCount}" FontSize="11" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Videos scanned" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding DetectionTab.VideoCount}" FontSize="11" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </TabItem>

        <!-- Sessions -->
        <TabItem Header="Sessions">
            <StackPanel>
                <TextBlock Text="Chrome Sessions" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                <Border Style="{StaticResource GlassPanelStyle}">
                    <TextBlock Text="30 Chrome profiles. Cookies via DPAPI + sql.js." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                </Border>
            </StackPanel>
        </TabItem>

        <!-- Projects -->
        <TabItem Header="Projects">
            <StackPanel>
                <TextBlock Text="OAuth Projects" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                <Border Style="{StaticResource GlassPanelStyle}">
                    <TextBlock Text="OAuth project management — requires Chrome cookie extraction (ported from Electron)." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                </Border>
            </StackPanel>
        </TabItem>

        <!-- API Keys -->
        <TabItem Header="API Keys">
            <StackPanel>
                <TextBlock Text="API Keys" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                <Border Style="{StaticResource GlassPanelStyle}">
                    <TextBlock Text="API key management for YouTube Data API v3." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                </Border>
            </StackPanel>
        </TabItem>

        <!-- Storage -->
        <TabItem Header="Storage">
            <StackPanel>
                <TextBlock Text="Storage" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="DISK USAGE" Style="{StaticResource SectionHeaderStyle}"/>
                        <ProgressBar Style="{StaticResource ProgressBarStyle}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Videos" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Output" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Blur Cache" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Clear Downloads" Style="{StaticResource GhostButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Clear Blur Cache" Style="{StaticResource GhostButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </TabItem>

        <!-- Diagnostics -->
        <TabItem Header="Diagnostics">
            <StackPanel>
                <TextBlock Text="Diagnostics" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                <Button Content="Run Diagnostics" Style="{StaticResource AccentButtonStyle}" Margin="0,0,0,16"/>
            </StackPanel>
        </TabItem>

        <!-- Logs -->
        <TabItem Header="Logs">
            <StackPanel>
                <TextBlock Text="Logs" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                <Border Style="{StaticResource GlassPanelStyle}" Padding="8">
                    <TextBlock Text="Log viewer — refresh and export logs from here." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                </Border>
            </StackPanel>
        </TabItem>

        <!-- Update -->
        <TabItem Header="Update">
            <StackPanel>
                <TextBlock Text="Update" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                <Border Style="{StaticResource GlassPanelStyle}">
                    <TextBlock Text="Current version: 1.0.0" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                </Border>
            </StackPanel>
        </TabItem>
    </TabControl>
</UserControl>
