<UserControl x:Class="HyperClip.UI.Views.InputBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardBorderStyle}" Padding="8,6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="UrlInput"
                     Text="{Binding InputUrl, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputTextBoxStyle}"
                     BorderThickness="0" Padding="4,0">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding AddAndDownloadCommand}"/>
                </TextBox.InputBindings>
            </TextBox>

            <TextBlock Grid.Column="0"
                       Text="Paste YouTube URL..."
                       Foreground="{StaticResource TextTertiaryBrush}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="8,0"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=UrlInput}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Grid.Column="0"
                       Text="{Binding InputError}"
                       Foreground="{StaticResource ErrorBrush}"
                       FontSize="10"
                       VerticalAlignment="Center"
                       Margin="8,0"
                       Visibility="{Binding InputError, Converter={StaticResource StringToVisibilityConverter}}"/>

            <Button Grid.Column="1"
                    Content="Add"
                    Command="{Binding AddAndDownloadCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="12,4"/>
        </Grid>
    </Border>
</UserControl>
