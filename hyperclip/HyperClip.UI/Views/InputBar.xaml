<UserControl x:Class="HyperClip.UI.Views.InputBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1" CornerRadius="4" Padding="8,6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="UrlInput"
                     Text="{Binding InputUrl, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent"
                     Foreground="#F5F5F5"
                     BorderThickness="0"
                     FontSize="12"
                     VerticalContentAlignment="Center"
                     Padding="4,0"
                     CaretBrush="#F5F5F5">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding AddAndDownloadCommand}"/>
                </TextBox.InputBindings>
            </TextBox>

            <TextBlock Grid.Column="0"
                       Text="Paste YouTube URL..."
                       Foreground="#555555"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="8,0"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=UrlInput}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Grid.Column="0"
                       Text="{Binding InputError}"
                       Foreground="#EF4444"
                       FontSize="10"
                       VerticalAlignment="Center"
                       Margin="8,0"
                       Visibility="{Binding InputError, Converter={StaticResource StringToVisibilityConverter}}"/>

            <Button Grid.Column="1"
                    Content="Add"
                    Command="{Binding AddAndDownloadCommand}"
                    Background="#3B82F6"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="12,4"
                    FontSize="11"
                    FontWeight="600"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</UserControl>
